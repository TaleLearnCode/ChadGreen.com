---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import PresentationCard from '../../components/cards/PresentationCard.astro';
import UnderConstructionBanner from '../../components/ui/UnderConstructionBanner.astro';
import { getCollection } from 'astro:content';

// Get all presentations and separate by status
let activePresentations: any[] = [];
let retiredPresentations: any[] = [];
try {
    const allPresentations = await getCollection('presentations');
    const sorted = allPresentations.sort((a, b) => {
        // Featured first, then by creation date
        if (a.data.featured && !b.data.featured) return -1;
        if (!a.data.featured && b.data.featured) return 1;
        const dateA = a.data.createdDate?.getTime() || 0;
        const dateB = b.data.createdDate?.getTime() || 0;
        return dateB - dateA;
    });

    // Separate by status
    activePresentations = sorted.filter(p => p.data.status !== 'retired');
    retiredPresentations = sorted.filter(p => p.data.status === 'retired');
} catch (e) {
    // Collection might not exist yet
}

// Group active presentations by type for filtering
const presentationTypes = [...new Set(activePresentations.map(p => p.data.type))];
---

<BaseLayout 
    title="Presentations" 
    description="Browse all presentations by Chad Green on Azure, .NET, DevOps, and more."
>
    <PageHeader title="Presentations">
        <p>Explore my collection of talks, workshops, and presentations</p>
    </PageHeader>

    <UnderConstructionBanner />
    <div class="container">
        <!-- Filter Controls -->
        {presentationTypes.length > 1 && (
            <div class="filter-controls">
                <button class="filter-btn active" data-filter="all">All</button>
                {presentationTypes.map((type) => (
                    <button class="filter-btn" data-filter={type}>
                        {type.replace('-', ' ').replace(/\b\w/g, l => l.toUpperCase())}
                    </button>
                ))}
            </div>
        )}

        <!-- Active & In-Development Presentations -->
        {activePresentations.length > 0 ? (
            <div class="presentations-grid grid grid-3" id="presentations-grid">
                {activePresentations.map((presentation) => (
                    <div class="presentation-item" data-type={presentation.data.type}>
                        <PresentationCard
                            title={presentation.data.title}
                            description={presentation.data.description}
                            slug={presentation.id}
                            thumbnail={presentation.data.heroImage}
                            presentationType={presentation.data.type}
                            tags={presentation.data.tags}
                            featured={presentation.data.featured}
                        />
                    </div>
                ))}
            </div>
        ) : (
            <div class="empty-state">
                <h3>No Presentations Yet</h3>
                <p>Check back soon for my collection of presentations.</p>
            </div>
        )}

        <!-- Retired Presentations Section -->
        {retiredPresentations.length > 0 && (
            <section class="retired-presentations">
                <h2>Archived Presentations</h2>
                <p class="retired-description">These presentations are no longer actively offered.</p>
                <div class="retired-table">
                    <div class="retired-header">
                        <div class="col-title">Title</div>
                        <div class="col-type">Type</div>
                    </div>
                    {retiredPresentations.map((presentation) => (
                        <a href={`/presentations/${presentation.id}`} class="retired-row">
                            <div class="col-title">{presentation.data.title}</div>
                            <div class="col-type">{presentation.data.type.replace('-', ' ').replace(/\b\w/g, l => l.toUpperCase())}</div>
                        </a>
                    ))}
                </div>
            </section>
        )}
    </div>

    <!-- Book CTA -->
    <section class="book-cta">
        <div class="container">
            <div class="cta-content">
                <p>
                    <strong>Interested in one of these presentations?</strong><br>
                    Email <a href="mailto:chadgreen@chadgreen.com">chadgreen@chadgreen.com</a> to have Chad present at your event.
                </p>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    .filter-controls {
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-2);
        margin-bottom: var(--spacing-8);
        justify-content: center;
    }

    .filter-btn {
        padding: var(--spacing-2) var(--spacing-4);
        background-color: var(--color-bg-secondary);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-full);
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-medium);
        color: var(--color-text-secondary);
        cursor: pointer;
        transition: all var(--transition-fast);
    }

    .filter-btn:hover {
        border-color: var(--color-primary);
        color: var(--color-primary);
    }

    .filter-btn.active {
        background-color: var(--color-primary);
        border-color: var(--color-primary);
        color: var(--color-text-inverse);
    }

    .presentation-item {
        transition: opacity var(--transition-fast);
    }

    .presentation-item.hidden {
        display: none;
    }

    .empty-state {
        text-align: center;
        padding: var(--spacing-16);
        background-color: var(--color-bg-secondary);
        border-radius: var(--radius-lg);
    }

    .empty-state h3 {
        margin-bottom: var(--spacing-2);
    }

    .empty-state p {
        color: var(--color-text-secondary);
        margin-bottom: 0;
    }

    .book-cta {
        background-color: var(--color-primary-bg);
        padding: var(--spacing-8) 0;
    }

    .book-cta .cta-content {
        text-align: center;
    }

    .book-cta a {
        color: var(--color-primary);
        font-weight: var(--font-weight-semibold);
    }

    /* Retired Presentations Section */
    .retired-presentations {
        margin-top: var(--spacing-16);
        padding-top: var(--spacing-16);
        border-top: 1px solid var(--color-border);
    }

    .retired-presentations h2 {
        margin-bottom: var(--spacing-2);
        font-size: var(--font-size-lg);
        font-weight: var(--font-weight-bold);
    }

    .retired-description {
        color: var(--color-text-secondary);
        margin-bottom: var(--spacing-4);
        font-size: var(--font-size-sm);
    }

    .retired-table {
        display: flex;
        flex-direction: column;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        overflow: hidden;
    }

    .retired-header {
        display: grid;
        grid-template-columns: 1fr 150px;
        gap: var(--spacing-4);
        background-color: var(--color-bg-secondary);
        padding: var(--spacing-3) var(--spacing-4);
        font-weight: var(--font-weight-semibold);
        font-size: var(--font-size-sm);
        color: var(--color-text-secondary);
    }

    .retired-row {
        display: grid;
        grid-template-columns: 1fr 150px;
        gap: var(--spacing-4);
        padding: var(--spacing-3) var(--spacing-4);
        border-top: 1px solid var(--color-border);
        text-decoration: none;
        color: inherit;
        transition: background-color var(--transition-fast);
    }

    .retired-row:first-of-type {
        border-top: none;
    }

    .retired-row:hover {
        background-color: var(--color-bg-secondary);
    }

    .col-title {
        font-weight: var(--font-weight-medium);
        color: var(--color-primary);
    }

    .col-type {
        font-size: var(--font-size-sm);
        color: var(--color-text-secondary);
    }

    @media (max-width: 768px) {
        .retired-header,
        .retired-row {
            grid-template-columns: 1fr;
        }

        .col-type {
            display: none;
        }

        .retired-header .col-type {
            display: none;
        }
    }</style>

<script>
    const filterBtns = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('.presentation-item');

    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const filter = (btn as HTMLElement).dataset.filter;

            // Update active state
            filterBtns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            // Filter items
            items.forEach(item => {
                const type = (item as HTMLElement).dataset.type;
                if (filter === 'all' || type === filter) {
                    item.classList.remove('hidden');
                } else {
                    item.classList.add('hidden');
                }
            });
        });
    });
</script>
