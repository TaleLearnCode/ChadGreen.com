---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Badge from '../../../../components/ui/Badge.astro';
import Button from '../../../../components/ui/Button.astro';
import TabNav from '../../../../components/ui/TabNav.astro';
import TabSyncScript from '../../../../components/ui/TabSyncScript.astro';
import { getCollection, render } from 'astro:content';
import { marked } from 'marked';

export async function getStaticPaths() {
    const meetupEvents = await getCollection('meetupEvents');
    const meetupGroups = await getCollection('meetupGroups');
    
    return meetupEvents.map((event) => {
        const group = meetupGroups.find(g => g.data.slug === event.data.meetupGroup);
        return {
            params: { 
                groupSlug: event.data.meetupGroup,
                eventSlug: event.id 
            },
            props: { event, group },
        };
    });
}

const { event, group } = Astro.props;
const { Content } = await render(event);

// Determine if event is upcoming or past
const now = new Date();
const eventDate = new Date(event.data.date);
const isUpcoming = eventDate >= now;

// Format date
const dateFormatter = new Intl.DateTimeFormat('en-US', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric'
});
const formattedDate = dateFormatter.format(eventDate);

const tabs = [
    { id: 'details', label: 'Event Details' },
    { id: 'speaker', label: 'About the Speaker' },
    { id: 'resources', label: 'Resources' },
];

// Get current tab from URL
const currentTab = Astro.url.searchParams.get('tab') || 'details';
---

<BaseLayout 
    title={event.data.title}
    description={event.data.description}
    ogImage={event.data.heroImage || event.data.thumbnail}
>
    <!-- Event Header -->
    <section class="event-header">
        <div class="container">
            <div class="header-content">
                {(event.data.heroImage || event.data.thumbnail) && (
                    <div class="header-image">
                        <img 
                            src={event.data.heroImage || event.data.thumbnail || '/images/meetups/default-meetup.svg'} 
                            alt="" 
                            loading="eager"
                        />
                    </div>
                )}
                <div class="header-info">
                    <div class="header-meta">
                        {group && (
                            <a href={`/meetups/${group.data.slug}`}>
                                <Badge variant="primary">{group.data.title}</Badge>
                            </a>
                        )}
                        <Badge variant={isUpcoming ? 'success' : 'outline'}>
                            {isUpcoming ? 'Upcoming' : 'Past Event'}
                        </Badge>
                    </div>
                    
                    <h1 class="event-title">{event.data.title}</h1>
                    
                    <div class="event-info">
                        <div class="info-item">
                            <span class="info-icon">📅</span>
                            <span>{formattedDate}</span>
                        </div>
                        {event.data.time && (
                            <div class="info-item">
                                <span class="info-icon">🕐</span>
                                <span>{event.data.time}</span>
                            </div>
                        )}
                        {event.data.location?.venue && (
                            <div class="info-item">
                                <span class="info-icon">📍</span>
                                <span>
                                    {event.data.location.venue}
                                    {event.data.location.city && `, ${event.data.location.city}`}
                                    {event.data.location.state && `, ${event.data.location.state}`}
                                </span>
                            </div>
                        )}
                    </div>

                    {event.data.shortDescription && (
                        <p class="event-short-description">{event.data.shortDescription}</p>
                    )}

                    <div class="header-actions">
                        {isUpcoming && event.data.eventUrl && (
                            <Button href={event.data.eventUrl} variant="primary" target="_blank" rel="noopener noreferrer">
                                RSVP on Meetup.com
                            </Button>
                        )}
                        {group && (
                            <Button href={`/meetups/${group.data.slug}`} variant="outline">
                                View All {group.data.title} Events
                            </Button>
                        )}
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Tab Navigation -->
    <div class="tabs-container">
        <div class="container">
            <TabNav 
                tabs={tabs.map(t => ({ ...t, href: `?tab=${t.id}` }))} 
                activeTab={currentTab} 
            />
        </div>
    </div>

    <!-- Tab Content -->
    <section class="section tab-content">
        <div class="container">
            <!-- Details Tab -->
            <div class="tab-panel" data-tab="details" style={currentTab !== 'details' ? 'display: none;' : ''}>
                <div class="prose">
                    <Content />
                </div>
            </div>

            <!-- Speaker Tab -->
            <div class="tab-panel" data-tab="speaker" style={currentTab !== 'speaker' ? 'display: none;' : ''}>
                {event.data.speaker ? (
                    <div class="speaker-info">
                        <div class="speaker-header">
                            {event.data.speaker.photo && (
                                <img src={event.data.speaker.photo} alt={event.data.speaker.name} class="speaker-photo" />
                            )}
                            <div class="speaker-details">
                                <h2>{event.data.speaker.name}</h2>
                                {event.data.speaker.title && (
                                    <p class="speaker-title">
                                        {event.data.speaker.title}
                                        {event.data.speaker.company && ` at ${event.data.speaker.company}`}
                                    </p>
                                )}
                                {event.data.speaker.social && (
                                    <div class="speaker-social">
                                        {event.data.speaker.social.website && (
                                            <a href={event.data.speaker.social.website} target="_blank" rel="noopener noreferrer" aria-label="Website">
                                                <svg class="social-icon" viewBox="0 0 24 24" aria-hidden="true">
                                                    <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                                                </svg>
                                            </a>
                                        )}
                                        {event.data.speaker.social.linkedin && (
                                            <a href={event.data.speaker.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                                                in
                                            </a>
                                        )}
                                        {event.data.speaker.social.twitter && (
                                            <a href={event.data.speaker.social.twitter.startsWith('http') ? event.data.speaker.social.twitter : `https://twitter.com/${event.data.speaker.social.twitter}`} target="_blank" rel="noopener noreferrer" aria-label="Twitter">
                                                𝕏
                                            </a>
                                        )}
                                        {event.data.speaker.social.github && (
                                            <a href={event.data.speaker.social.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                                                <svg class="social-icon" viewBox="0 0 24 24" aria-hidden="true">
                                                    <path fill="currentColor" d="M12 1.5c-5.8 0-10.5 4.7-10.5 10.5 0 4.6 3 8.5 7.1 9.9.5.1.7-.2.7-.5v-1.9c-2.9.6-3.5-1.2-3.5-1.2-.5-1.2-1.2-1.5-1.2-1.5-1-.7.1-.7.1-.7 1.1.1 1.7 1.1 1.7 1.1 1 .1.9 1.7 2.8 1.7.2-.7.4-1.1.7-1.4-2.3-.3-4.7-1.2-4.7-5.1 0-1.1.4-2 1.1-2.8-.1-.3-.5-1.4.1-2.8 0 0 .9-.3 2.9 1.1.8-.2 1.7-.4 2.6-.4s1.8.1 2.6.4c2-1.4 2.9-1.1 2.9-1.1.6 1.4.2 2.5.1 2.8.7.8 1.1 1.7 1.1 2.8 0 4-2.4 4.8-4.7 5.1.4.3.7.9.7 1.9v2.8c0 .3.2.6.7.5 4.1-1.4 7.1-5.3 7.1-9.9C22.5 6.2 17.8 1.5 12 1.5z"/>
                                                </svg>
                                            </a>
                                        )}
                                        {event.data.speaker.social.youtube && (
                                            <a href={event.data.speaker.social.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube">
                                                ▶
                                            </a>
                                        )}
                                        {event.data.speaker.social.sessionize && (
                                            <a href={event.data.speaker.social.sessionize} target="_blank" rel="noopener noreferrer" aria-label="Sessionize">
                                                <svg class="social-icon" viewBox="0 0 288 288" aria-hidden="true">
                                                    <path fill="currentColor" d="M0 0 C0.66 0 1.32 0 2 0 C2.1952124 0.53665283 2.3904248 1.07330566 2.59155273 1.6262207 C13.88022447 32.45486643 28.56058295 60.7451903 51.57275391 84.52148438 C53.05641746 86.05844409 54.51772277 87.61501765 55.98046875 89.171875 C69.14572675 102.97302573 84.49161439 113.57396083 101 123 C101.69029297 123.39670898 102.38058594 123.79341797 103.09179688 124.20214844 C115.70986798 131.37724797 129.78542825 138.75697778 144 142 C144 142.66 144 143.32 144 144 C127.05908203 151.52929688 110.11816406 159.05859375 93.17724609 166.58789062 C92.24720764 167.00124161 91.31716919 167.41459259 90.35894775 167.84046936 C88.50327723 168.66521068 86.64760503 169.48994824 84.79193115 170.31468201 C80.17488732 172.36668172 75.55787307 174.41874792 70.94091797 176.47094727 C62.26888893 180.325514 53.59659599 184.17948324 44.92330933 188.03121948 C40.89554105 189.81996501 36.86793119 191.60906707 32.84033203 193.39819336 C30.94832061 194.23853922 29.05623442 195.07871676 27.1640625 195.91870117 C14.42520427 201.57387727 1.70506426 207.26929574 -11 213 C-7.69105274 215.68756979 -4.41788955 218.01572329 -0.75 220.1875 C14.22291468 229.70112139 24.53768989 245.41257386 28.6875 262.5625 C30.48674659 270.99157912 31 278.233547 31 287 C19.12 287 7.24 287 -5 287 C-5.66 282.05 -6.32 277.1 -7 272 C-10.91137988 260.48936779 -15.70023301 252.94504795 -26.703125 247.3828125 C-40.92409236 241.41809396 -54.61841556 239.86349032 -69.91601562 239.5703125 C-76.78055822 239.34101671 -82.6975894 238.64653114 -88.2421875 234.203125 C-93.57868928 227.81974967 -95.53605434 222.42904844 -95 214 C-94.14283211 211.13575071 -92.94061489 208.46849553 -91.6953125 205.75390625 C-91.34499969 204.96314194 -90.99468689 204.17237762 -90.63375854 203.35765076 C-89.47642796 200.75360167 -88.30085404 198.15823092 -87.125 195.5625 C-86.30357099 193.72380568 -85.483277 191.88460392 -84.6640625 190.04492188 C-82.53960045 185.2832126 -80.39951