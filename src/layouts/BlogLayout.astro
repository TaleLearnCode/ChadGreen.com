---
import SidebarLayout from './SidebarLayout.astro';
import Badge from '../components/ui/Badge.astro';

export interface Props {
    title: string;
    description: string;
    pubDate: Date;
    updatedDate?: Date;
    heroImage?: string;
    heroImageAlt?: string;
    category?: string;
    tags?: string[];
    author?: string;
}

const {
    title,
    description,
    pubDate,
    updatedDate,
    heroImage,
    heroImageAlt = '',
    category = 'Other',
    tags = [],
    author = 'Chad Green',
} = Astro.props;

function formatDate(date: Date): string {
    return date.toLocaleDateString('en-US', {
        weekday: 'long',
        year: 'numeric',
        month: 'long',
        day: 'numeric',
    });
}
---

<SidebarLayout title={title} description={description} ogImage={heroImage} specificTags={tags}>
    <article class="blog-article">
        <header class="article-header">
            <div class="article-meta">
                <Badge variant="primary">{category}</Badge>
                <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
                {updatedDate && (
                    <span class="updated">
                        (Updated: <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>)
                    </span>
                )}
            </div>
            
            <h1 class="article-title">{title}</h1>
            
            <p class="article-description">{description}</p>
            
            <div class="article-author">
                <span>By {author}</span>
            </div>
        </header>

        {heroImage && (
            <div class="article-hero">
                <img src={heroImage} alt={heroImageAlt} loading="eager" />
            </div>
        )}

        <div class="article-content">
            <slot />
        </div>

        {tags.length > 0 && (
            <footer class="article-footer">
                <div class="article-tags">
                    <span class="tags-label">Tags:</span>
                    {tags.map((tag) => (
                        <a href={`/blog/tags/${encodeURIComponent(tag)}`} class="tag">{tag}</a>
                    ))}
                </div>
            </footer>
        )}
    </article>
</SidebarLayout>

<style>
    .blog-article {
        max-width: 100%;
    }

    .article-header {
        margin-bottom: var(--spacing-8);
    }

    .article-meta {
        display: flex;
        align-items: center;
        gap: var(--spacing-3);
        margin-bottom: var(--spacing-4);
        flex-wrap: wrap;
    }

    .article-meta time {
        font-size: var(--font-size-sm);
        color: var(--color-text-muted);
    }

    .updated {
        font-size: var(--font-size-sm);
        color: var(--color-text-muted);
        font-style: italic;
    }

    .article-title {
        font-size: var(--font-size-4xl);
        font-weight: var(--font-weight-bold);
        line-height: 1.2;
        margin-bottom: var(--spacing-4);
    }

    .article-description {
        font-size: var(--font-size-xl);
        color: var(--color-text-secondary);
        line-height: var(--line-height-relaxed);
        margin-bottom: var(--spacing-4);
    }

    .article-author {
        font-size: var(--font-size-sm);
        color: var(--color-text-secondary);
    }

    .article-hero {
        margin-bottom: var(--spacing-8);
        border-radius: var(--radius-lg);
        overflow: hidden;
    }

    .article-hero img {
        width: 100%;
        height: auto;
    }

    .article-content {
        font-size: var(--font-size-lg);
        line-height: var(--line-height-relaxed);
    }

    .article-content :global(h2) {
        font-size: var(--font-size-2xl);
        margin-top: var(--spacing-10);
        margin-bottom: var(--spacing-4);
    }

    .article-content :global(h3) {
        font-size: var(--font-size-xl);
        margin-top: var(--spacing-8);
        margin-bottom: var(--spacing-3);
    }

    .article-content :global(p) {
        margin-bottom: var(--spacing-6);
    }

    .article-content :global(img) {
        border-radius: var(--radius-md);
        margin: var(--spacing-6) 0;
    }

    .article-content :global(blockquote) {
        border-left: 4px solid var(--color-primary);
        padding-left: var(--spacing-4);
        margin: var(--spacing-6) 0;
        font-style: italic;
        color: var(--color-text-secondary);
    }

    .article-content :global(ul),
    .article-content :global(ol) {
        margin-bottom: var(--spacing-6);
        padding-left: var(--spacing-6);
    }

    .article-content :global(li) {
        margin-bottom: var(--spacing-2);
    }

    .article-footer {
        margin-top: var(--spacing-10);
        padding-top: var(--spacing-6);
        border-top: 1px solid var(--color-border);
    }

    .article-tags {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--spacing-2);
    }

    .tags-label {
        font-weight: var(--font-weight-medium);
        color: var(--color-text-secondary);
    }

    .tag {
        display: inline-block;
        padding: var(--spacing-1) var(--spacing-3);
        background-color: var(--color-bg-secondary);
        color: var(--color-text-secondary);
        font-size: var(--font-size-sm);
        border-radius: var(--radius-full);
        text-decoration: none;
        transition: all var(--transition-fast);
    }

    .tag:hover {
        background-color: var(--color-primary-bg);
        color: var(--color-primary);
    }

    @media (max-width: 768px) {
        .article-title {
            font-size: var(--font-size-3xl);
        }

        .article-description {
            font-size: var(--font-size-lg);
        }

        .article-content {
            font-size: var(--font-size-base);
        }
    }
</style>
