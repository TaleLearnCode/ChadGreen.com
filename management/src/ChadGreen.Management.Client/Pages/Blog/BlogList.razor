@page "/blog"
@inject ManagementApiHttpClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Blog Posts</PageTitle>

<div class="oc-page-shell">
    <div class="oc-page-header">
        <div class="oc-page-title-group">
            <h1>Blog Posts</h1>
            <p class="oc-page-subtitle">Manage publish state and featured placement for site articles.</p>
        </div>
        <div class="oc-page-actions">
            <button class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/blog/new"))">New Blog Post</button>
            <button class="btn btn-outline-secondary" @onclick="LoadAsync" disabled="@_isLoading">Refresh</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="alert oc-feedback @(_isError ? "alert-danger" : "alert-success")">@_message</div>
    }

    @if (_isLoading)
    {
        <p class="oc-state-panel" data-state="loading">Loading blog posts...</p>
    }
    else if (_items.Count == 0)
    {
        <p class="oc-state-panel" data-state="empty">No blog posts found.</p>
    }
    else
    {
        <div class="oc-list-surface">
            <table class="table table-striped table-sm align-middle">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Published</th>
                        <th>Category</th>
                        <th>Draft</th>
                        <th>Featured</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _items)
                    {
                        <tr>
                            <td>
                                <a href="@($"/blog/{item.Slug}")">@item.Title</a>
                                <div class="text-muted small">@item.Description</div>
                            </td>
                            <td>@item.PubDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.Category</td>
                            <td>
                                <span class="badge oc-status-chip" data-status="@(item.Draft ? "draft" : "active")">
                                    @(item.Draft ? "Draft" : "Published")
                                </span>
                            </td>
                            <td>
                                <span class="badge oc-status-chip" data-status="@(item.Featured ? "featured" : "not-featured")">
                                    @(item.Featured ? "Featured" : "Standard")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<BlogListItemDto> _items = [];
    private bool _isLoading = true;
    private string? _message;
    private bool _isError;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _message = null;
        _isError = false;

        try
        {
            _items = (await ApiClient.GetBlogPostsAsync()).ToList();
        }
        catch (Exception exception)
        {
            _isError = true;
            _message = exception.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }
}
