@page "/blog"
@inject ManagementApiHttpClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Blog Posts</PageTitle>

<h1>Blog Posts</h1>

<div class="mb-3 d-flex gap-2">
    <button class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/blog/new"))">New Blog Post</button>
    <button class="btn btn-outline-secondary" @onclick="LoadAsync" disabled="@_isLoading">Refresh</button>
</div>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert @(_isError ? "alert-danger" : "alert-success")">@_message</div>
}

@if (_isLoading)
{
    <p>Loading blog posts...</p>
}
else if (_items.Count == 0)
{
    <p>No blog posts found.</p>
}
else
{
    <table class="table table-striped table-sm align-middle">
        <thead>
            <tr>
                <th>Title</th>
                <th>Published</th>
                <th>Category</th>
                <th>Draft</th>
                <th>Featured</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in _items)
            {
                <tr>
                    <td>
                        <a href="@($"/blog/{item.Slug}")">@item.Title</a>
                        <div class="text-muted small">@item.Description</div>
                    </td>
                    <td>@item.PubDate.ToString("yyyy-MM-dd")</td>
                    <td>@item.Category</td>
                    <td>@(item.Draft ? "Yes" : "No")</td>
                    <td>@(item.Featured ? "Yes" : "No")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<BlogListItemDto> _items = [];
    private bool _isLoading = true;
    private string? _message;
    private bool _isError;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _message = null;
        _isError = false;

        try
        {
            _items = (await ApiClient.GetBlogPostsAsync()).ToList();
        }
        catch (Exception exception)
        {
            _isError = true;
            _message = exception.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }
}
