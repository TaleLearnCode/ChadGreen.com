@page "/engagements"
@inject ManagementApiHttpClient ApiClient
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Speaking Engagements</PageTitle>

<h1>Speaking Engagements</h1>

<div class="mb-3 d-flex gap-2">
    <button class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/engagements/new"))">New Event</button>
    <button class="btn btn-outline-secondary" @onclick="LoadAsync" disabled="@_isLoading">Refresh</button>
</div>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert @(_isError ? "alert-danger" : "alert-success")">@_message</div>
}

@if (_isLoading)
{
    <p>Loading engagements...</p>
}
else if (_items.Count == 0)
{
    <p>No engagements found.</p>
}
else
{
    <table class="table table-striped table-sm align-middle">
        <thead>
            <tr>
                <th>Event</th>
                <th>Date</th>
                <th>Presentations</th>
                <th>Featured</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in _items)
            {
                <tr>
                    <td>
                        <a href="@($"/engagements/{item.Slug}")">@item.Title</a>
                        <div class="text-muted small">@item.EventType</div>
                    </td>
                    <td>@item.StartDate.ToString("yyyy-MM-dd")</td>
                    <td>@item.PresentationCount</td>
                    <td>
                        <input type="checkbox" checked="@item.Featured" @onchange="eventArgs => OnFeaturedChangedAsync(item, eventArgs.Value is true)" />
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ArchiveAsync(item)">Archive</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<EngagementListItemDto> _items = [];
    private bool _isLoading = true;
    private string? _message;
    private bool _isError;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _message = null;
        _isError = false;

        try
        {
            _items = (await ApiClient.GetEngagementsAsync()).ToList();
        }
        catch (Exception exception)
        {
            _isError = true;
            _message = exception.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnFeaturedChangedAsync(EngagementListItemDto item, bool featured)
    {
        try
        {
            var updated = await ApiClient.UpdateEngagementFeaturedAsync(item.Slug, featured);
            item = item with { Featured = updated.Featured };
            ReplaceItem(item);
            _message = $"Updated featured flag for '{item.Title}'.";
            _isError = false;
        }
        catch (Exception exception)
        {
            _isError = true;
            _message = exception.Message;
        }
    }

    private async Task ArchiveAsync(EngagementListItemDto item)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Archive '{item.Title}'?"))
        {
            return;
        }

        try
        {
            await ApiClient.ArchiveEngagementAsync(item.Slug);
            _items.RemoveAll(candidate => candidate.Slug == item.Slug);
            _message = $"Archived '{item.Title}'.";
            _isError = false;
        }
        catch (Exception exception)
        {
            _isError = true;
            _message = exception.Message;
        }
    }

    private void ReplaceItem(EngagementListItemDto item)
    {
        var index = _items.FindIndex(candidate => candidate.Slug == item.Slug);
        if (index >= 0)
        {
            _items[index] = item;
        }
    }
}
