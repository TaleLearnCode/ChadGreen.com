@page "/meetup-events"
@inject ManagementApiHttpClient ApiClient
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Meetup Events</PageTitle>

<div class="oc-page-shell">
    <div class="oc-page-header">
        <div class="oc-page-title-group">
            <h1>Meetup Events</h1>
            <p class="oc-page-subtitle">Review meetup event status, group linkage, and archival actions.</p>
        </div>
        <div class="oc-page-actions">
            <button class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/meetup-events/new"))">New Meetup Event</button>
            <button class="btn btn-outline-secondary" @onclick="LoadAsync" disabled="@_isLoading">Refresh</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="alert oc-feedback @(_isError ? "alert-danger" : "alert-success")">@_message</div>
    }

    @if (_isLoading)
    {
        <p class="oc-state-panel" data-state="loading">Loading meetup events...</p>
    }
    else if (_items.Count == 0)
    {
        <p class="oc-state-panel" data-state="empty">No meetup events found.</p>
    }
    else
    {
        <div class="oc-list-surface">
            <table class="table table-striped table-sm align-middle">
                <thead>
                    <tr>
                        <th>Event</th>
                        <th>Date</th>
                        <th>Group</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _items)
                    {
                        <tr>
                            <td><a href="@($"/meetup-events/{item.Slug}")">@item.Title</a></td>
                            <td>@item.Date.ToString("yyyy-MM-dd")</td>
                            <td><a href="@($"/meetup-groups/{item.MeetupGroup}")">@item.MeetupGroup</a></td>
                            <td>
                                <span class="badge oc-status-chip" data-status="@item.Status">@item.Status</span>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ArchiveAsync(item)">Archive</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<MeetupEventListItemDto> _items = [];
    private bool _isLoading = true;
    private string? _message;
    private bool _isError;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _message = null;
        _isError = false;

        try
        {
            _items = (await ApiClient.GetMeetupEventsAsync()).ToList();
        }
        catch (Exception exception)
        {
            _isError = true;
            _message = exception.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ArchiveAsync(MeetupEventListItemDto item)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Archive '{item.Title}'?"))
        {
            return;
        }

        try
        {
            await ApiClient.ArchiveMeetupEventAsync(item.Slug);
            _items.RemoveAll(candidate => candidate.Slug == item.Slug);
            _message = $"Archived '{item.Title}'.";
            _isError = false;
        }
        catch (Exception exception)
        {
            _isError = true;
            _message = exception.Message;
        }
    }
}
