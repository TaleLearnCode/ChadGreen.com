@page "/meetup-groups/new"
@page "/meetup-groups/{Slug}"
@implements IDisposable
@inject ManagementApiHttpClient ApiClient
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>@(_isNew ? "New Meetup Group" : $"Edit {_model.Title}")</PageTitle>

<h1>@(_isNew ? "New Meetup Group" : "Edit Meetup Group")</h1>

<NavigationLock ConfirmExternalNavigation="_hasUnsavedChanges" OnBeforeInternalNavigation="ConfirmInternalNavigationAsync" />

<div class="mb-3 d-flex gap-2">
    <button class="btn btn-outline-secondary" @onclick="@(() => Navigation.NavigateTo("/meetup-groups"))">Back to List</button>
    @if (!_isNew)
    {
        <button class="btn btn-outline-danger" @onclick="ArchiveAsync">Archive</button>
    }
</div>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert @(_isError ? "alert-danger" : "alert-success")">@_message</div>
}

@if (_isLoading)
{
    <p>Loading meetup group...</p>
}
else
{
    <EditForm EditContext="_editContext" OnValidSubmit="SaveAsync">
        <div class="row g-3">
            <div class="col-md-8">
                <label class="form-label">Title</label>
                <InputText class="form-control" @bind-Value="_model.Title" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Slug</label>
                <InputText class="form-control" @bind-Value="_model.Slug" />
            </div>
            <div class="col-12">
                <label class="form-label">Description</label>
                <InputTextArea class="form-control" rows="4" @bind-Value="_model.Description" />
            </div>
            <div class="col-md-4">
                <label class="form-label">City</label>
                <InputText class="form-control" @bind-Value="_model.City" />
            </div>
            <div class="col-md-4">
                <label class="form-label">State</label>
                <InputText class="form-control" @bind-Value="_model.State" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Country</label>
                <InputText class="form-control" @bind-Value="_model.Country" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Website</label>
                <InputText class="form-control" @bind-Value="_model.Website" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Role</label>
                <InputText class="form-control" @bind-Value="_model.Role" />
            </div>
            <div class="col-md-9">
                <MediaPickerField Label="Hero Image" PreviewAlt="Hero image preview" @bind-Value="_model.HeroImage" />
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <div class="form-check">
                    <InputCheckbox class="form-check-input" @bind-Value="_model.Featured" />
                    <label class="form-check-label">Featured</label>
                </div>
            </div>
            <div class="col-12">
                <label class="form-label">Markdown Body</label>
                <InputTextArea class="form-control" rows="16" @bind-Value="_model.MarkdownBody" />
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary" disabled="@_isSaving">Save</button>
            <button type="button" class="btn btn-outline-primary" @onclick="SaveAndCommitAsync" disabled="@_isSaving || !_gitCommitAvailable">Save + Commit</button>
        </div>
    </EditForm>

    @if (!_isNew)
    {
        <div class="card mt-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h2 class="h5 mb-0">Events</h2>
                    <button class="btn btn-sm btn-outline-primary"
                            disabled="@string.IsNullOrWhiteSpace(LinkedGroupSlug)"
                            @onclick="@(() => Navigation.NavigateTo($"/meetup-events/new?groupSlug={Uri.EscapeDataString(LinkedGroupSlug!)}"))">New Event for Group</button>
                </div>

                @if (_relatedEvents.Count == 0)
                {
                    <p class="text-muted mb-0">No meetup events currently linked to this group.</p>
                }
                else
                {
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var eventItem in _relatedEvents)
                            {
                                <tr>
                                    <td><a href="@($"/meetup-events/{eventItem.Slug}?groupSlug={Uri.EscapeDataString(_model.Slug)}")">@eventItem.Title</a></td>
                                    <td>@eventItem.Date.ToString("yyyy-MM-dd")</td>
                                    <td>@eventItem.Status</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }

    <div class="card mt-3">
        <div class="card-body">
            <h2 class="h5">Commit Details</h2>
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Type</label>
                    <InputSelect class="form-select" @bind-Value="_commit.Type">
                        <option value="@ConventionalCommitType.Feat">feat</option>
                        <option value="@ConventionalCommitType.Fix">fix</option>
                        <option value="@ConventionalCommitType.Docs">docs</option>
                        <option value="@ConventionalCommitType.Refactor">refactor</option>
                        <option value="@ConventionalCommitType.Chore">chore</option>
                    </InputSelect>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Scope</label>
                    <InputText class="form-control" @bind-Value="_commit.Scope" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Description</label>
                    <InputText class="form-control" @bind-Value="_commit.Description" />
                </div>
                <div class="col-12">
                    <label class="form-label">Body (optional)</label>
                    <InputTextArea class="form-control" rows="3" @bind-Value="_commit.Body" />
                </div>
            </div>
            @if (!_gitCommitAvailable)
            {
                <p class="text-muted mb-0 mt-2">Save + Commit is unavailable (git integration disabled or unavailable).</p>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string? Slug { get; set; }

    private readonly MeetupGroupEditModel _model = new();
    private readonly EditContext _editContext;
    private readonly CommitDraft _commit = new() { Type = ConventionalCommitType.Chore, Scope = "meetups" };
    private bool _isNew => string.IsNullOrWhiteSpace(Slug);
    private bool _isLoading = true;
    private bool _isSaving;
    private bool _gitCommitAvailable;
    private bool _hasUnsavedChanges;
    private string? _message;
    private bool _isError;
    private DateTimeOffset? _expectedLastModifiedUtc;
    private List<MeetupGroupEventSummaryDto> _relatedEvents = [];
    private string? LinkedGroupSlug => _isNew ? null : Slug;
    private string? HeroImagePreviewUrl => HeroImagePreviewResolver.Resolve(_model.HeroImage);

    public MeetupGroupEdit()
    {
        _editContext = new EditContext(_model);
        _editContext.OnFieldChanged += HandleFieldChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _message = null;
        _isError = false;

        try
        {
            await LoadGitCapabilityAsync();
            if (_isNew)
            {
                ResetDefaults();
                _relatedEvents = [];
                _hasUnsavedChanges = false;
            }
            else
            {
                var detail = await ApiClient.GetMeetupGroupAsync(Slug!);
                if (detail is null)
                {
                    _isError = true;
                    _message = "Meetup group not found.";
                    return;
                }

                MapFromDetail(detail);
                _hasUnsavedChanges = false;
            }
        }
        catch (Exception exception)
        {
            _isError = true;
            _message = exception.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SaveAsync() => await SaveInternalAsync(commitAfterSave: false);

    private async Task SaveAndCommitAsync() => await SaveInternalAsync(commitAfterSave: true);

    private async Task SaveInternalAsync(bool commitAfterSave)
    {
        _isSaving = true;
        _message = null;
        _isError = false;

        try
        {
            var request = new MeetupGroupUpsertRequest(
                _model.Title.Trim(),
                string.IsNullOrWhiteSpace(_model.Slug) ? null : _model.Slug.Trim(),
                _model.Description.Trim(),
                _model.City.Trim(),
                string.IsNullOrWhiteSpace(_model.State) ? null : _model.State.Trim(),
                _model.Country.Trim(),
                string.IsNullOrWhiteSpace(_model.Website) ? null : _model.Website.Trim(),
                string.IsNullOrWhiteSpace(_model.Role) ? null : _model.Role.Trim(),
                _model.Featured,
                string.IsNullOrWhiteSpace(_model.HeroImage) ? null : _model.HeroImage.Trim(),
                _model.MarkdownBody ?? string.Empty,
                _isNew ? null : _expectedLastModifiedUtc);

            var detail = _isNew
                ? await ApiClient.CreateMeetupGroupAsync(request)
                : await ApiClient.UpdateMeetupGroupAsync(Slug!, request);

            MapFromDetail(detail);
            if (_isNew)
            {
                Slug = detail.Slug;
                Navigation.NavigateTo($"/meetup-groups/{detail.Slug}", forceLoad: false);
            }

            _message = $"Saved '{detail.Title}'.";
            _hasUnsavedChanges = false;

            if (commitAfterSave)
            {
                var commitRequest = new CommitRequest(
                    _commit.Type,
                    string.IsNullOrWhiteSpace(_commit.Description) ? $"update meetup group {_model.Slug}" : _commit.Description.Trim(),
                    string.IsNullOrWhiteSpace(_commit.Scope) ? null : _commit.Scope.Trim(),
                    string.IsNullOrWhiteSpace(_commit.Body) ? null : _commit.Body.Trim(),
                    IncludeAllChanges: true);
                var commitResponse = await ApiClient.CommitAsync(commitRequest);
                _message = $"{_message} Commit: {commitResponse.CommitSha ?? "(no sha)"}";
            }
        }
        catch (Exception exception)
        {
            _isError = true;
            _message = exception.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task ArchiveAsync()
    {
        if (_isNew)
        {
            return;
        }

        if (!await JS.InvokeAsync<bool>("confirm", $"Archive '{_model.Title}'?"))
        {
            return;
        }

        try
        {
            await ApiClient.ArchiveMeetupGroupAsync(Slug!);
            _hasUnsavedChanges = false;
            Navigation.NavigateTo("/meetup-groups");
        }
        catch (Exception exception)
        {
            _isError = true;
            _message = exception.Message;
        }
    }

    private async Task LoadGitCapabilityAsync()
    {
        var capability = await ApiClient.GetGitCapabilityAsync();
        _gitCommitAvailable = capability?.Enabled == true && capability.IsRepository && capability.GitCliAvailable;
    }

    private void MapFromDetail(MeetupGroupDetailDto detail)
    {
        _model.Title = detail.Title;
        _model.Slug = detail.Slug;
        _model.Description = detail.Description;
        _model.City = detail.City;
        _model.State = detail.State ?? string.Empty;
        _model.Country = detail.Country;
        _model.Website = detail.Website ?? string.Empty;
        _model.Role = detail.Role ?? string.Empty;
        _model.Featured = detail.Featured;
        _model.HeroImage = detail.HeroImage;
        _model.MarkdownBody = detail.MarkdownBody;
        _expectedLastModifiedUtc = detail.LastModifiedUtc;
        _relatedEvents = (detail.RelatedEvents ?? [])
            .OrderByDescending(item => item.Date)
            .ThenBy(item => item.Title, StringComparer.OrdinalIgnoreCase)
            .ToList();
        _commit.Description = $"update meetup group {detail.Slug}";
    }

    private void ResetDefaults()
    {
        _model.Title = string.Empty;
        _model.Slug = string.Empty;
        _model.Description = string.Empty;
        _model.City = string.Empty;
        _model.State = string.Empty;
        _model.Country = "USA";
        _model.Website = string.Empty;
        _model.Role = string.Empty;
        _model.Featured = false;
        _model.HeroImage = "/images/meetups/default-meetup.svg";
        _model.MarkdownBody = string.Empty;
        _expectedLastModifiedUtc = null;
        _commit.Description = "add meetup group";
    }

    private async Task ConfirmInternalNavigationAsync(LocationChangingContext context)
    {
        if (!_hasUnsavedChanges)
        {
            return;
        }

        var shouldLeave = await JS.InvokeAsync<bool>("confirm", "You have unsaved changes. Leave without saving?");
        if (!shouldLeave)
        {
            context.PreventNavigation();
        }
    }

    private void HandleFieldChanged(object? sender, FieldChangedEventArgs e) => _hasUnsavedChanges = true;

    public void Dispose()
    {
        _editContext.OnFieldChanged -= HandleFieldChanged;
    }

    private sealed class MeetupGroupEditModel
    {
        public string Title { get; set; } = string.Empty;
        public string Slug { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string City { get; set; } = string.Empty;
        public string State { get; set; } = string.Empty;
        public string Country { get; set; } = "USA";
        public string Website { get; set; } = string.Empty;
        public string Role { get; set; } = string.Empty;
        public bool Featured { get; set; }
        public string HeroImage { get; set; } = "/images/meetups/default-meetup.svg";
        public string MarkdownBody { get; set; } = string.Empty;
    }

    private sealed class CommitDraft
    {
        public ConventionalCommitType Type { get; set; } = ConventionalCommitType.Chore;
        public string? Scope { get; set; }
        public string Description { get; set; } = string.Empty;
        public string? Body { get; set; }
    }
}
