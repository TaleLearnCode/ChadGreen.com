@page "/utilities"
@inject ManagementApiHttpClient ApiClient

<PageTitle>System Utilities</PageTitle>

<h1>System Utilities</h1>

<p class="text-muted">Run dead-link and missing-image scans, then review actionable issues by source file and field path.</p>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert @(_isError ? "alert-danger" : "alert-success")">@_message</div>
}

@if (_isLoading)
{
    <p>Loading utility dashboard...</p>
}
else
{
    <div class="row g-3">
        @foreach (var scan in _dashboardItems)
        {
            var scanKey = ToScanKey(scan.ScanType);
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h2 class="h5 mb-0">@GetScanTitle(scan.ScanType)</h2>
                            <button class="btn btn-sm btn-outline-primary" disabled="@(_isRunningScan == scan.ScanType)" @onclick="@(() => RunScanAsync(scan.ScanType))">
                                @(_isRunningScan == scan.ScanType ? "Running..." : "Run Scan")
                            </button>
                        </div>
                        <div class="small text-muted mb-2">
                            Last run:
                            @if (scan.LastRunAtUtc is null)
                            {
                                <span>never</span>
                            }
                            else
                            {
                                <span>@scan.LastRunAtUtc.Value.ToLocalTime().ToString("g")</span>
                            }
                        </div>
                        @if (scan.Summary is null)
                        {
                            <p class="mb-0 text-muted">No results yet.</p>
                        }
                        else
                        {
                            <div class="d-flex gap-3 flex-wrap small">
                                <span>Checked: <strong>@scan.Summary.TotalChecked</strong></span>
                                <span class="text-danger">Errors: <strong>@scan.Summary.Errors</strong></span>
                                <span class="text-warning">Warnings: <strong>@scan.Summary.Warnings</strong></span>
                                <span class="text-secondary">Issues: <strong>@scan.Summary.Issues</strong></span>
                            </div>
                        }
                        <div class="mt-3">
                            <button class="btn btn-sm @(IsSelected(scan.ScanType) ? "btn-primary" : "btn-outline-secondary")" @onclick="@(() => SelectScan(scan.ScanType))">
                                View Results
                            </button>
                            @if (scan.LastRunAtUtc is not null && !_latestResults.ContainsKey(scan.ScanType))
                            {
                                <button class="btn btn-sm btn-link" @onclick="@(() => LoadLatestResultAsync(scan.ScanType))">Load latest</button>
                            }
                        </div>
                        <div class="small text-muted mt-2">Key: @scanKey</div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="mt-4">
        <h2 class="h4">@GetScanTitle(_selectedScanType) Results</h2>
        @if (!_latestResults.TryGetValue(_selectedScanType, out var selectedResult))
        {
            <p class="text-muted">Run or load this scan to view actionable rows.</p>
        }
        else if (selectedResult.Issues.Count == 0)
        {
            <div class="alert alert-success mb-0">No issues found in the latest scan.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Severity</th>
                            <th>Source file</th>
                            <th>Field/path</th>
                            <th>Issue</th>
                            <th>Target</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var issue in selectedResult.Issues)
                        {
                            <tr>
                                <td>@issue.Severity</td>
                                <td><code>@issue.SourceFile</code></td>
                                <td>@(string.IsNullOrWhiteSpace(issue.FieldPath) ? "-" : issue.FieldPath)</td>
                                <td>@issue.Issue</td>
                                <td>@(string.IsNullOrWhiteSpace(issue.Target) ? "-" : issue.Target)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@code {
    private bool _isLoading = true;
    private bool _isError;
    private string? _message;
    private UtilityScanType? _isRunningScan;
    private List<UtilityDashboardItem> _dashboardItems = [];
    private readonly Dictionary<UtilityScanType, UtilityScanResult> _latestResults = [];
    private UtilityScanType _selectedScanType = UtilityScanType.DeadLinks;

    protected override async Task OnInitializedAsync()
    {
        await RefreshDashboardAsync();
    }

    private async Task RefreshDashboardAsync()
    {
        _isLoading = true;
        _message = null;
        _isError = false;
        try
        {
            var dashboard = await ApiClient.GetUtilityDashboardAsync();
            _dashboardItems = dashboard?.Scans.OrderBy(item => item.ScanType).ToList() ?? [];
        }
        catch (Exception exception)
        {
            _isError = true;
            _message = exception.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task RunScanAsync(UtilityScanType scanType)
    {
        _isRunningScan = scanType;
        _isError = false;
        _message = null;
        try
        {
            var result = await ApiClient.RunUtilityScanAsync(ToScanKey(scanType));
            _latestResults[scanType] = result;
            _selectedScanType = scanType;
            await RefreshDashboardAsync();
            _message = $"{GetScanTitle(scanType)} completed. {result.Summary.Issues} issue(s) found.";
        }
        catch (Exception exception)
        {
            _isError = true;
            _message = exception.Message;
        }
        finally
        {
            _isRunningScan = null;
        }
    }

    private async Task LoadLatestResultAsync(UtilityScanType scanType)
    {
        _isError = false;
        _message = null;
        try
        {
            var result = await ApiClient.GetLatestUtilityScanAsync(ToScanKey(scanType));
            if (result is null)
            {
                _message = $"{GetScanTitle(scanType)} has no persisted result yet.";
                return;
            }

            _latestResults[scanType] = result;
            _selectedScanType = scanType;
        }
        catch (Exception exception)
        {
            _isError = true;
            _message = exception.Message;
        }
    }

    private void SelectScan(UtilityScanType scanType) => _selectedScanType = scanType;

    private bool IsSelected(UtilityScanType scanType) => _selectedScanType == scanType;

    private static string ToScanKey(UtilityScanType scanType)
        => scanType switch
        {
            UtilityScanType.DeadLinks => "dead-links",
            UtilityScanType.MissingImages => "missing-images",
            _ => "dead-links"
        };

    private static string GetScanTitle(UtilityScanType scanType)
        => scanType switch
        {
            UtilityScanType.DeadLinks => "Dead-link Scan",
            UtilityScanType.MissingImages => "Missing-image Scan",
            _ => scanType.ToString()
        };
}
