{
  "name": "chad-green-website",
  "type": "module",
  "version": "1.0.0",
  "description": "Personal website for Chad Green - Speaker, Community Leader",
  "scripts": {
    "dev": "astro dev",
    "dev:site": "astro dev",
    "dev:client": "astro dev",
    "dev:api": "npx -y azure-functions-core-tools@4 start --script-root api",
    "dev:management": "node -e \"console.log('Management app startup (use two terminals):\\n  1) npm run dev:management:prepare\\n  2) npm run dev:management:api\\n  3) npm run dev:management:client')\"",
    "dev:management:prepare": "dotnet build .\\management\\ChadGreen.Management.slnx",
    "dev:management:api": "dotnet run --no-build --project .\\management\\src\\ChadGreen.Management.Api\\ChadGreen.Management.Api.csproj --launch-profile http",
    "dev:management:client": "dotnet run --no-build --project .\\management\\src\\ChadGreen.Management.Client\\ChadGreen.Management.Client.csproj --launch-profile http",
    "check:management:launcher": "run-management.cmd --check",
    "setup:api": "npm --prefix api install --no-audit --no-fund",
    "start": "astro dev",
    "build:site": "astro build",
    "build:client": "astro build",
    "build:management": "dotnet build .\\management\\ChadGreen.Management.slnx",
    "build:management:api": "dotnet build .\\management\\src\\ChadGreen.Management.Api\\ChadGreen.Management.Api.csproj",
    "build:management:client": "dotnet build .\\management\\src\\ChadGreen.Management.Client\\ChadGreen.Management.Client.csproj",
    "build": "astro build",
    "preview:site": "astro preview",
    "preview": "astro preview",
    "astro": "astro",
    "postinstall": "playwright install"
  },
  "dependencies": {
    "astro": "^5.0.0",
    "marked": "^17.0.2",
    "rehype-mermaid": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "playwright": "^1.58.2",
    "typescript": "^5.3.0"
  }
}
